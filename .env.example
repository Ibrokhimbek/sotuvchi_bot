# Asosiy
bot_token=your_telegram_bot_token_from_botfather
gemini_key=your_gemini_api_key_from_aistudio
gemini_model=gemini-2.5-flash
db_path=data/bot.db
log_level=INFO

# Gemini cache (system prompt 217KB — har so'rovda yubormaslik uchun)
enable_gemini_cache=true

# Anti-spam: bitta foydalanuvchidan minimal interval (soniya)
throttle_seconds=1.2

# Operator chat ID — handoff signal yuboriladigan joy
# Telegram guruh ID (-100... formatda) yoki shaxsiy ID
operator_chat_id=

# ElevenLabs TTS (ixtiyoriy — bo'sh qolsa, voice javoblar o'chiriladi)
elevenlabs_key=
elevenlabs_voice_id=EXAVITQu4vr4xnSDxMaL
voice_probability=0.18
