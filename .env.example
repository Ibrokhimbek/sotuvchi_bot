# Asosiy
bot_token=your_telegram_bot_token_from_botfather
gemini_key=your_gemini_api_key_from_aistudio
gemini_model=gemini-2.5-flash
db_path=data/bot.db
log_level=INFO

# Gemini cache (system prompt 217KB — har so'rovda yubormaslik uchun)
enable_gemini_cache=true

# Button-mashing'dan himoya (pacing asosiy rate kontrolni ushlaydi)
throttle_seconds=0.3

# Operator chat ID — handoff signal yuboriladigan joy
# Telegram guruh ID (-100... formatda) yoki shaxsiy ID
operator_chat_id=

# Google Sheets webhook (Apps Script Web App URL)
# Bo'sh qoldirilsa — kontaktlar faqat SQLite da saqlanadi
gsheets_webhook_url=

# Mijoz kontakt yuborganidan keyin Nozimaxon necha soniyada birinchi salomlashishi
delayed_greeting_seconds=40

# AmoCRM integratsiyasi (har suhbat lead sifatida saqlanadi)
# Bo'sh qoldirilsa AmoCRM'ga yozilmaydi
amocrm_subdomain=
amocrm_token=
amocrm_pipeline_name=POS New

# AmoCRM Chats API (amojo) — to'liq chat panel integratsiya
# Support'dan oling: channel_id, secret. account_id JWT'dan: 32040830
amocrm_account_id=
amocrm_chat_channel_id=
amocrm_chat_channel_secret=
# scope_id ni `python -m scripts.amocrm_chat_connect` ishga tushirgandan keyin to'ldiring
amocrm_chat_scope_id=
# amoMarket'da yaratilgan tashqi integratsiyaning UUID (bot ref_id sifatida)
amocrm_chat_client_uuid=
# Outgoing bot xabarlari MANAGER nomidan keladi — Manager amojo_id'si.
# Agar bo'sh bo'lsa, bot startda /api/v4/users orqali avtomatik aniqlaydi
# (token egasi). Ko'rinishni o'zgartirmoqchi bo'lsangiz boshqa manager amojo_id'sini bering
amocrm_manager_amojo_id=

# Yangi chat lead'ini avtomatik Telegram etapiga ko'chirish (POS New voronkasida)
# Pipeline va etap ID'larini /api/v4/leads/pipelines orqali topish mumkin
amocrm_pipeline_id=9857042
amocrm_telegram_stage_id=86024566
amocrm_chat_default_stage_id=78392566

# === Webhook rejimi (--webhook flag bilan ishlatiladi) ===
# webhook_url: Telegram qaerga POST qiladi (ngrok URL yoki domeningiz)
# Misol: https://abc123.ngrok.io
webhook_url=
webhook_path=/telegram/webhook
webhook_host=0.0.0.0
webhook_port=8080
# Telegram'dan kelgan request'larni tasdiqlash uchun maxfiy token (ixtiyoriy lekin tavsiya)
webhook_secret=

# AmoCRM Telegram integratsiyasi webhook URL'i — har incoming update
# shu URL'ga ham yo'naltiriladi. Bo'sh qoldirilsa forwarding o'chiriladi
amocrm_telegram_webhook_url=
